# ================================================
#  SAFEPASS - VARIAVEIS DE AMBIENTE
#  Ambiente: Desenvolvimento Local
#
#  IMPORTANTE:
#  - Nunca commite este arquivo no Git!
#  - Adicione .env no seu .gitignore
#  - Para producao, use variaveis de ambiente
#    diretamente no servidor ou Docker
# ================================================

# ----------------
# SERVIDOR
# ----------------
SERVER_PORT=8080

# ----------------
# URLs
# ----------------
APP_BASE_URL=http://localhost:{SERVER_PORT}
APP_FRONTEND_URL=http://localhost:3000

# ----------------
# BANCO DE DADOS - MySQL
# Formato: jdbc:mysql://<host>:<porta>/<nome-do-banco>?parametros
# ----------------
DB_URL=jdbc:mysql://localhost:3306/safepass_db?useSSL=false&serverTimezone=America/Sao_Paulo&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=5517

# ----------------
# JWT

# ----------------
JWT_SECRET=SSifda86af5safasf8asfas9fg1m3mp2jk056236m263bn86oi72h6n98u7g6hn534n768bw578907bw89w7apoiK
JWT_EXPIRATION_MS=604800000

# ----------------
# GOOGLE OAUTH2
# 3. Tipo: Aplicativo da Web
# 4. URI de redirecionamento autorizado:
#    http://localhost:8080/login/oauth2/code/google
# ----------------
GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_CLIENT_SECRET

# ----------------
# EMAIL (Gmail)
# ----------------
MAIL_USERNAME=seuemail@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx